; =====================================================
; ПРИМЕР ПОЛЬЗОВАТЕЛЬСКИХ ПЕРЕМЕННЫХ
; Переименуйте в custom.conf и раскомментируйте нужные
; =====================================================

[globals]
; =====================================================
; ПРЕДПРИЯТИЕ
; =====================================================
; COMPANY_NAME = "ООО Название Компании"
; COMPANY_CODE = COMP001
; DEPARTMENT_DEFAULT = "Отдел безопасности"
; NOTIFICATION_EMAIL = security@company.ru
; EMERGENCY_CONTACT = +7 (999) 123-45-67

; =====================================================
; РАСШИРЕННЫЕ НАСТРОЙКИ ТЕЛЕФОНИИ
; =====================================================
; Дополнительные кодеки
; ALLOW_VIDEO_CODECS = no
; VIDEO_CODECS = h264,vp8

; NAT настройки
; EXTERNAL_IP = 
; LOCAL_NET = 192.168.0.0/16,10.0.0.0/8
; NAT_MODE = auto_force_rport

; =====================================================
; ИНТЕГРАЦИИ
; =====================================================
; SMS шлюз
; SMS_GATEWAY_URL = 
; SMS_API_KEY = 
; SMS_ENABLED = no

; Email
; SMTP_HOST = smtp.company.ru
; SMTP_PORT = 587
; SMTP_USER = gochs@company.ru
; SMTP_PASSWORD = 

; =====================================================
; ОСОБЫЕ РЕЖИМЫ РАБОТЫ
; =====================================================
; Режим повышенной готовности
; HIGH_ALERT_MODE = no
; HIGH_ALERT_MAX_CHANNELS = 50
; HIGH_ALERT_PRIORITY = 1

; Ночной режим
; NIGHT_MODE_ENABLED = no
; NIGHT_MODE_START = 22:00
; NIGHT_MODE_END = 07:00
; NIGHT_MODE_ACTION = voicemail

; =====================================================
; СПЕЦИФИЧНЫЕ НОМЕРА И ГРУППЫ
; =====================================================
; Группы руководителей
; MANAGEMENT_GROUP = 100,101,102
; SECURITY_GROUP = 200,201,202
; IT_GROUP = 300,301,302

; Важные номера
; DIRECTOR_NUMBER = 100
; SECURITY_CHIEF = 200
; IT_ADMIN = 300

; =====================================================
; ПРАЗДНИЧНЫЕ И ВЫХОДНЫЕ ДНИ
; =====================================================
; HOLIDAYS_FILE = ${GOCHS_BASE}/config/holidays.txt
; WEEKEND_DAYS = sat,sun
; SPECIAL_SCHEDULE_ENABLED = no
