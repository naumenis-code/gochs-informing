################################################################################
# ГО-ЧС Информирование - Основной конфигурационный файл
# Версия: 1.0.0
# Дата генерации: $(date '+%Y-%m-%d %H:%M:%S')
################################################################################

# ============================================================================
# 1. ОБЩИЕ НАСТРОЙКИ СИСТЕМЫ
# ============================================================================

# Название системы
SYSTEM_NAME="ГО-ЧС Информирование"
SYSTEM_VERSION="1.0.0"
SYSTEM_ENVIRONMENT="production"  # production | development | testing

# Пути установки
INSTALL_DIR="/opt/gochs-informing"
BACKUP_DIR="${INSTALL_DIR}/backups"
LOG_DIR="${INSTALL_DIR}/logs"
TEMP_DIR="/tmp/gochs"

# Временная зона
TIMEZONE="Europe/Moscow"
LOCALE="ru_RU.UTF-8"

# ============================================================================
# 2. СЕТЕВЫЕ НАСТРОЙКИ
# ============================================================================

# Домен или IP-адрес сервера
DOMAIN_OR_IP="192.168.1.100"  # Измените на ваш IP или домен

# Порты
HTTP_PORT=80
HTTPS_PORT=443
API_PORT=8000
WEBSOCKET_PORT=8001

# Настройки прокси (если используется)
PROXY_ENABLED="no"
PROXY_HOST=""
PROXY_PORT=""
PROXY_USER=""
PROXY_PASSWORD=""

# ============================================================================
# 3. БАЗА ДАННЫХ POSTGRESQL
# ============================================================================

# Основные настройки
POSTGRES_VERSION="15"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="gochs"
POSTGRES_USER="gochs_user"
POSTGRES_PASSWORD="GChs_DB_P@ssw0rd_2024!_ChangeMe"  # ИЗМЕНИТЬ ПРИ УСТАНОВКЕ!

# Оптимизация PostgreSQL
POSTGRES_MAX_CONNECTIONS="200"
POSTGRES_SHARED_BUFFERS="512MB"
POSTGRES_EFFECTIVE_CACHE_SIZE="1536MB"
POSTGRES_MAINTENANCE_WORK_MEM="128MB"
POSTGRES_WORK_MEM="16MB"
POSTGRES_WAL_LEVEL="replica"
POSTGRES_MAX_WAL_SIZE="4GB"
POSTGRES_MIN_WAL_SIZE="1GB"

# Резервное копирование
POSTGRES_BACKUP_ENABLED="yes"
POSTGRES_BACKUP_TIME="02:00"  # Ежедневно в 2:00
POSTGRES_BACKUP_RETENTION_DAYS="30"

# ============================================================================
# 4. REDIS
# ============================================================================

# Основные настройки
REDIS_VERSION="7.2"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="GChs_Redis_P@ssw0rd_2024!_ChangeMe"  # ИЗМЕНИТЬ ПРИ УСТАНОВКЕ!
REDIS_DB="0"

# Оптимизация Redis
REDIS_MAXMEMORY="512mb"
REDIS_MAXMEMORY_POLICY="allkeys-lru"
REDIS_SAVE_SECONDS="300"
REDIS_SAVE_CHANGES="100"
REDIS_APPENDONLY="yes"
REDIS_APPENDFSYNC="everysec"

# Дополнительные БД Redis (для разных задач)
REDIS_CACHE_DB="1"      # Для кэширования
REDIS_SESSION_DB="2"    # Для сессий
REDIS_QUEUE_DB="3"      # Для очередей Celery
REDIS_WEBSOCKET_DB="4"  # Для WebSocket

# ============================================================================
# 5. ASTERISK (ТЕЛЕФОННОЕ ЯДРО)
# ============================================================================

# Версия и пути
ASTERISK_VERSION="20"
ASTERISK_FULL_VERSION="20.7.0"
ASTERISK_ETC_DIR="/etc/asterisk"
ASTERISK_LIB_DIR="/var/lib/asterisk"
ASTERISK_LOG_DIR="/var/log/asterisk"
ASTERISK_SPOOL_DIR="/var/spool/asterisk"

# SIP настройки
ASTERISK_SIP_PORT="5060"
ASTERISK_SIP_TRANSPORT="udp,tcp"  # udp | tcp | tls
ASTERISK_RTP_START="10000"
ASTERISK_RTP_END="20000"

# AMI (Asterisk Manager Interface)
ASTERISK_AMI_ENABLED="yes"
ASTERISK_AMI_HOST="127.0.0.1"
ASTERISK_AMI_PORT="5038"
ASTERISK_AMI_USER="gochs_ami"
ASTERISK_AMI_PASSWORD="GChs_AMI_P@ssw0rd_2024!_ChangeMe"  # ИЗМЕНИТЬ ПРИ УСТАНОВКЕ!

# ARI (Asterisk REST Interface)
ASTERISK_ARI_ENABLED="yes"
ASTERISK_ARI_HOST="127.0.0.1"
ASTERISK_ARI_PORT="8088"
ASTERISK_ARI_USER="gochs"
ASTERISK_ARI_PASSWORD="GChs_ARI_P@ssw0rd_2024!_ChangeMe"  # ИЗМЕНИТЬ ПРИ УСТАНОВКЕ!
ASTERISK_ARI_PREFIX="ari"

# Интеграция с FreePBX
FREEPBX_ENABLED="yes"
FREEPBX_HOST="192.168.1.10"  # Измените на IP вашего FreePBX
FREEPBX_PORT="5060"
FREEPBX_EXTENSION="gochs"
FREEPBX_USERNAME="gochs"
FREEPBX_PASSWORD="FreePBX_P@ssw0rd_ChangeMe"  # ИЗМЕНИТЬ ПРИ УСТАНОВКЕ!
FREEPBX_TRANSPORT="udp"  # udp | tcp | tls

# Кодеки (в порядке приоритета)
ASTERISK_CODECS="ulaw,alaw,g729,opus,gsm"

# Лимиты звонков
ASTERISK_MAX_CALLS="100"
ASTERISK_MAX_CONCURRENT_CALLS="50"

# ============================================================================
# 6. BACKEND (FASTAPI)
# ============================================================================

# Основные настройки
BACKEND_HOST="0.0.0.0"
BACKEND_PORT="8000"
BACKEND_WORKERS="4"
BACKEND_DEBUG="false"
BACKEND_RELOAD="false"

# Безопасность
SECRET_KEY="$(openssl rand -base64 32 | tr -d '\n')"  # Генерируется автоматически
JWT_SECRET_KEY="$(openssl rand -base64 32 | tr -d '\n')"  # Генерируется автоматически
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES="60"
REFRESH_TOKEN_EXPIRE_DAYS="7"

# CORS
CORS_ORIGINS="http://localhost:3000,https://${DOMAIN_OR_IP}"
CORS_ALLOW_CREDENTIALS="true"

# Логирование
LOG_LEVEL="INFO"  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"  # json | text
LOG_MAX_SIZE="100MB"
LOG_BACKUP_COUNT="10"

# Ограничения API
API_RATE_LIMIT="100/minute"
API_MAX_REQUESTS="1000"
API_TIMEOUT="30"

# ============================================================================
# 7. FRONTEND (REACT)
# ============================================================================

# Настройки сборки
FRONTEND_PORT="3000"
FRONTEND_DEV_SERVER="false"
FRONTEND_SOURCE_MAP="false"
FRONTEND_MINIFY="true"
FRONTEND_COMPRESS="true"

# Настройки UI
UI_THEME="default"  # default | dark | light
UI_LANGUAGE="ru"
UI_DATE_FORMAT="DD.MM.YYYY"
UI_TIME_FORMAT="HH:mm:ss"
UI_PAGINATION_SIZE="20"

# ============================================================================
# 8. TTS (СИНТЕЗ РЕЧИ)
# ============================================================================

# Настройки Coqui TTS
TTS_ENABLED="yes"
TTS_ENGINE="coqui"  # coqui | espeak | festival
TTS_MODEL_PATH="${INSTALL_DIR}/models/tts"
TTS_LANGUAGE="ru"
TTS_VOICE="ruslan"  # Доступные: ruslan, ksenia, natasha
TTS_SAMPLE_RATE="22050"
TTS_SPEED="1.0"  # 0.5 - 2.0
TTS_VOLUME="1.0"  # 0.0 - 1.0

# Кэширование TTS
TTS_CACHE_ENABLED="yes"
TTS_CACHE_DIR="${INSTALL_DIR}/generated_voice"
TTS_CACHE_MAX_SIZE="10GB"
TTS_CACHE_TTL="2592000"  # 30 дней в секундах

# ============================================================================
# 9. STT (РАСПОЗНАВАНИЕ РЕЧИ)
# ============================================================================

# Настройки Vosk
STT_ENABLED="yes"
STT_ENGINE="vosk"  # vosk | whisper
STT_MODEL_PATH="${INSTALL_DIR}/models/vosk/model-ru"
STT_MODEL_SIZE="small"  # small | big
STT_SAMPLE_RATE="16000"
STT_LANGUAGE="ru"
STT_ALTERNATIVES="3"  # Количество альтернативных распознаваний

# Whisper (опционально)
STT_WHISPER_ENABLED="no"
STT_WHISPER_MODEL="base"  # tiny | base | small | medium | large
STT_WHISPER_LANGUAGE="ru"

# ============================================================================
# 10. ОПОВЕЩЕНИЯ И ОБЗВОН
# ============================================================================

# Общие настройки
NOTIFICATION_MAX_CHANNELS="20"
NOTIFICATION_MAX_RETRIES="3"
NOTIFICATION_RETRY_INTERVAL="300"  # секунды
NOTIFICATION_RETRY_MULTIPLIER="2"  # Множитель для exponential backoff
NOTIFICATION_MAX_DURATION="3600"  # Максимальная длительность кампании (сек)

# Таймауты
NOTIFICATION_DIAL_TIMEOUT="40"  # секунды
NOTIFICATION_ANSWER_TIMEOUT="30"  # секунды
NOTIFICATION_MESSAGE_TIMEOUT="300"  # секунды

# Рабочие часы
WORKING_HOURS_ENABLED="no"
WORKING_HOURS_START="09:00"
WORKING_HOURS_END="21:00"
WORKING_DAYS="1,2,3,4,5"  # 1=Пн, 7=Вс

# Приоритеты
PRIORITY_LEVELS="1-10"  # 1 - наивысший
DEFAULT_PRIORITY="5"

# ============================================================================
# 11. ЗАПИСЬ ЗВОНКОВ
# ============================================================================

# Настройки записи
RECORDING_ENABLED="yes"
RECORDING_FORMAT="wav"  # wav | mp3 | ogg
RECORDING_SAMPLE_RATE="8000"  # 8000 для телефонии
RECORDING_CHANNELS="1"  # mono
RECORDING_BITRATE="64k"

# Хранение записей
RECORDING_DIR="${INSTALL_DIR}/recordings"
RECORDING_RETENTION_DAYS="90"  # Срок хранения
RECORDING_MAX_SIZE="100GB"  # Максимальный общий размер
RECORDING_COMPRESSION="yes"

# ============================================================================
# 12. БЕЗОПАСНОСТЬ
# ============================================================================

# Парольная политика
PASSWORD_MIN_LENGTH="8"
PASSWORD_REQUIRE_UPPERCASE="yes"
PASSWORD_REQUIRE_LOWERCASE="yes"
PASSWORD_REQUIRE_NUMBERS="yes"
PASSWORD_REQUIRE_SPECIAL="no"
PASSWORD_EXPIRE_DAYS="90"

# Блокировка
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_MINUTES="15"
LOCKOUT_RESET_HOURS="24"

# Сессии
SESSION_TIMEOUT_MINUTES="60"
MAX_CONCURRENT_SESSIONS="3"

# Шифрование
ENCRYPTION_KEY="$(openssl rand -base64 32 | tr -d '\n')"
ENCRYPTION_ALGORITHM="AES-256-GCM"

# Аудит
AUDIT_ENABLED="yes"
AUDIT_LOG_ACTIONS="all"  # all | critical | none
AUDIT_RETENTION_DAYS="365"

# ============================================================================
# 13. МОНИТОРИНГ
# ============================================================================

# Prometheus метрики
PROMETHEUS_ENABLED="yes"
PROMETHEUS_PORT="9090"
PROMETHEUS_PATH="/metrics"

# Health checks
HEALTH_CHECK_INTERVAL="30"  # секунды
HEALTH_CHECK_TIMEOUT="10"   # секунды

# Алерты
ALERTS_ENABLED="no"
ALERTS_EMAIL="${ADMIN_EMAIL}"
ALERTS_WEBHOOK_URL=""

# Мониторинг ресурсов
MONITOR_CPU_THRESHOLD="80"  # %
MONITOR_MEMORY_THRESHOLD="80"  # %
MONITOR_DISK_THRESHOLD="80"  # %
MONITOR_CHANNELS_THRESHOLD="90"  # %

# ============================================================================
# 14. РЕЗЕРВНОЕ КОПИРОВАНИЕ
# ============================================================================

# Автоматическое резервное копирование
BACKUP_ENABLED="yes"
BACKUP_SCHEDULE="0 2 * * *"  # Ежедневно в 2:00
BACKUP_TYPE="full"  # full | incremental | differential
BACKUP_COMPRESSION="gzip"

# Что копировать
BACKUP_INCLUDE_DB="yes"
BACKUP_INCLUDE_CONFIG="yes"
BACKUP_INCLUDE_RECORDINGS="no"  # Может быть очень большим
BACKUP_INCLUDE_LOGS="no"

# Хранение бэкапов
BACKUP_RETENTION_DAILY="7"
BACKUP_RETENTION_WEEKLY="4"
BACKUP_RETENTION_MONTHLY="3"

# Удаленное хранение (опционально)
BACKUP_REMOTE_ENABLED="no"
BACKUP_REMOTE_TYPE="sftp"  # sftp | ftp | s3
BACKUP_REMOTE_HOST=""
BACKUP_REMOTE_USER=""
BACKUP_REMOTE_PASSWORD=""
BACKUP_REMOTE_PATH="/backups"

# ============================================================================
# 15. ОЧИСТКА И ОБСЛУЖИВАНИЕ
# ============================================================================

# Автоматическая очистка
CLEANUP_ENABLED="yes"
CLEANUP_SCHEDULE="0 3 * * 0"  # Каждое воскресенье в 3:00

# Что очищать
CLEANUP_OLD_RECORDINGS="yes"
CLEANUP_OLD_LOGS="yes"
CLEANUP_OLD_SESSIONS="yes"
CLEANUP_TEMP_FILES="yes"

# Пороги очистки
CLEANUP_RECORDINGS_DAYS="90"
CLEANUP_LOGS_DAYS="30"
CLEANUP_SESSIONS_DAYS="7"
CLEANUP_TEMP_HOURS="24"

# ============================================================================
# 16. ИНТЕГРАЦИИ (ОПЦИОНАЛЬНО)
# ============================================================================

# Email уведомления
SMTP_ENABLED="no"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="gochs@localhost"
SMTP_TLS="yes"

# SMS (через шлюз)
SMS_ENABLED="no"
SMS_GATEWAY=""
SMS_API_KEY=""
SMS_SENDER="GOCHS"

# Telegram
TELEGRAM_ENABLED="no"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Внешние API
EXTERNAL_API_ENABLED="no"
EXTERNAL_API_URL=""
EXTERNAL_API_KEY=""

# ============================================================================
# 17. РАЗРАБОТКА И ОТЛАДКА
# ============================================================================

# Режим разработки
DEV_MODE="false"
DEBUG="false"
VERBOSE="false"

# Профилирование
PROFILING_ENABLED="false"
PROFILING_SAMPLE_RATE="0.1"  # 10% запросов

# Тестирование
TEST_MODE="false"
TEST_DB_NAME="gochs_test"
MOCK_SERVICES="false"

# ============================================================================
# 18. КАСТОМНЫЕ ПАРАМЕТРЫ
# ============================================================================

# Дополнительные параметры, специфичные для предприятия
CUSTOM_PARAM_1=""
CUSTOM_PARAM_2=""
CUSTOM_PARAM_3=""

# ============================================================================
# ВЕРСИЯ КОНФИГУРАЦИИ
# ============================================================================
CONFIG_VERSION="1.0.0"
CONFIG_GENERATED="$(date '+%Y-%m-%d %H:%M:%S')"
CONFIG_LAST_MODIFIED="$(date '+%Y-%m-%d %H:%M:%S')"

################################################################################
# КОНЕЦ КОНФИГУРАЦИОННОГО ФАЙЛА
################################################################################
